export default {
      async fetch(request, env) {
          const url = new URL(request.url);
              const path = url.pathname;

                  const playlist1URL = "https://hntv.netlify.app/pa-id.html";
                      const playlist2URL = "https://hntv.netlify.app/pa-id2.html";
                          const altStreamURL = "https://hntv.netlify.app/free-playlist";
                              const FORCED_REFERER = "https://hntv.netlify.app/pa-id.html";

                                  let allowedDevices = JSON.parse(await env.HONOR_KV.get("allowedDevices") || "[]");
                                      let detectedDevices = JSON.parse(await env.HONOR_KV.get("detectedDevices") || "[]");
                                          let lastUA = await env.HONOR_KV.get("lastUA") || "None";
                                              let lastPlaylist = await env.HONOR_KV.get("lastPlaylist") || "None";

                                                  /* ================= HELPERS ================= */

                                                      function getDeviceID(ua) {
                                                            const match = ua.match(/; ([^;]+)\)$/);
                                                                  return match ? match[1].trim() : "unknown-device";
                                                                      }

                                                                          function getAppName(ua) {
                                                                                ua = ua.toLowerCase();
                                                                                      if (ua.includes("ott navigator")) return "OTT Navigator";
                                                                                            if (ua.includes("ott player")) return "OTT Player";
                                                                                                  if (ua.includes("ott tv")) return "OTT TV";
                                                                                                        return "Unknown OTT App";
                                                                                                            }

                                                                                                                function isExpired(dateStr) {
                                                                                                                      if (!dateStr) return false;
                                                                                                                            return new Date(dateStr) < new Date();
                                                                                                                                }

                                                                                                                                    function removeExpiredDevices(devices) {
                                                                                                                                          const now = new Date();
                                                                                                                                                return devices.filter(d => !d.expiry || new Date(d.expiry) >= now);
                                                                                                                                                    }

                                                                                                                                                        // 🔥 Auto delete expired allowed devices
                                                                                                                                                            const cleaned = removeExpiredDevices(allowedDevices);
                                                                                                                                                                if (cleaned.length !== allowedDevices.length) {
                                                                                                                                                                      allowedDevices = cleaned;
                                                                                                                                                                            await env.HONOR_KV.put("allowedDevices", JSON.stringify(allowedDevices));
                                                                                                                                                                                }

                                                                                                                                                                                    /* ================= HOME ================= */
                                                                                                                                                                                        if (path === "/") {
                                                                                                                                                                                              return new Response(`<h1>📺 HONOR TV PH</h1>`, {
                                                                                                                                                                                                      headers: { "Content-Type": "text/html; charset=UTF-8" }
                                                                                                                                                                                                            });
                                                                                                                                                                                                                }

                                                                                                                                                                                                                    /* ================= PLAYLIST ================= */
                                                                                                                                                                                                                        async function servePlaylist(ottURL, playlistName) {
                                                                                                                                                                                                                              const ua = request.headers.get("user-agent") || "Unknown UA";
                                                                                                                                                                                                                                    const deviceID = getDeviceID(ua);
                                                                                                                                                                                                                                          const appName = getAppName(ua);

                                                                                                                                                                                                                                                await env.HONOR_KV.put("lastUA", ua);
                                                                                                                                                                                                                                                      await env.HONOR_KV.put("lastPlaylist", playlistName);

                                                                                                                                                                                                                                                            let found = detectedDevices.find(d => d.deviceID === deviceID);
                                                                                                                                                                                                                                                                  if (found) {
                                                                                                                                                                                                                                                                          found.count++;
                                                                                                                                                                                                                                                                                  found.lastSeen = new Date().toLocaleString();
                                                                                                                                                                                                                                                                                          found.ua = ua;
                                                                                                                                                                                                                                                                                                  found.appName = appName;
                                                                                                                                                                                                                                                                                                        } else {
                                                                                                                                                                                                                                                                                                                detectedDevices.push({ deviceID, ua, appName, count: 1, lastSeen: new Date().toLocaleString() });
                                                                                                                                                                                                                                                                                                                      }
                                                                                                                                                                                                                                                                                                                            await env.HONOR_KV.put("detectedDevices", JSON.stringify(detectedDevices));

                                                                                                                                                                                                                                                                                                                                  const device = allowedDevices.find(d => d.deviceID === deviceID);
                                                                                                                                                                                                                                                                                                                                        const allowed = device && !isExpired(device.expiry);
                                                                                                                                                                                                                                                                                                                                              const finalURL = allowed ? ottURL : altStreamURL;

                                                                                                                                                                                                                                                                                                                                                    const response = await fetch(finalURL, {
                                                                                                                                                                                                                                                                                                                                                            headers: {
                                                                                                                                                                                                                                                                                                                                                                      "User-Agent": ua,
                                                                                                                                                                                                                                                                                                                                                                                "Referer": FORCED_REFERER,
                                                                                                                                                                                                                                                                                                                                                                                          "Origin": FORCED_REFERER
                                                                                                                                                                                                                                                                                                                                                                                                  }
                                                                                                                                                                                                                                                                                                                                                                                                        });

                                                                                                                                                                                                                                                                                                                                                                                                              return new Response(response.body, {
                                                                                                                                                                                                                                                                                                                                                                                                                      headers: {
                                                                                                                                                                                                                                                                                                                                                                                                                                "Content-Type": "application/vnd.apple.mpegurl",
                                                                                                                                                                                                                                                                                                                                                                                                                                          "Access-Control-Allow-Origin": "*"
                                                                                                                                                                                                                                                                                                                                                                                                                                                  }
                                                                                                                                                                                                                                                                                                                                                                                                                                                        });
                                                                                                                                                                                                                                                                                                                                                                                                                                                            }

                                                                                                                                                                                                                                                                                                                                                                                                                                                                if (path === "/playlist1.m3u") return servePlaylist(playlist1URL, "playlist1");
                                                                                                                                                                                                                                                                                                                                                                                                                                                                    if (path === "/playlist2.m3u") return servePlaylist(playlist2URL, "playlist2");

                                                                                                                                                                                                                                                                                                                                                                                                                                                                        /* ================= DASHBOARD ================= */
                                                                                                                                                                                                                                                                                                                                                                                                                                                                            if (path === "/hrtvdashboard" && request.method === "GET") {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  const query = (url.searchParams.get("search") || "").toLowerCase();

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        const filteredAllowed = allowedDevices.filter(d =>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                d.name?.toLowerCase().includes(query) ||
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        d.deviceID?.toLowerCase().includes(query)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              );

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    const filteredDetected = detectedDevices.filter(d =>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            d.deviceID?.toLowerCase().includes(query) ||
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    d.ua?.toLowerCase().includes(query) ||
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            d.appName?.toLowerCase().includes(query)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  );

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        return new Response(`
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              <html>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    <head>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <meta charset="UTF-8">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    <style>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              body { background:#111;color:#fff;font-family:sans-serif;padding:20px }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        .card { border:1px solid #333;padding:10px;margin:8px 0;border-radius:8px }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  input { margin:3px }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            button { margin-top:4px }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    </style>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          </head>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <body>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      <h1>📺 HONOR TV PH Dashboard</h1>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <p><b>Last Playlist:</b> ${lastPlaylist}</p>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <p><b>Last UA:</b><br>${lastUA}</p>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <form method="GET">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                🔍 <input name="search" placeholder="Search device..." value="${query}">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <button>Search</button>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              </form>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    <h2>✅ Allowed Devices</h2>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          ${filteredAllowed.map(d=>`
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <div class="card">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <form method="POST" action="/hrtvdashboard/edit">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <input type="hidden" name="oldDeviceID" value="${d.deviceID}">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    Name:<br>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <input name="name" value="${d.name || ""}"><br>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            Device ID:<br>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <input name="deviceID" value="${d.deviceID}"><br>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    Expiry:<br>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <input type="date" name="expiry" value="${d.expiry || ""}"><br>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <button>💾 Save Changes</button>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      </form>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <form method="POST" action="/hrtvdashboard/delete">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <input type="hidden" name="deviceID" value="${d.deviceID}">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <button>❌ Delete</button>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  </form>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            ${isExpired(d.expiry) ? "<b style='color:red'>EXPIRED</b>" : ""}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          `).join("")}

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <h3>Add Device</h3>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      <form method="POST" action="/hrtvdashboard/add">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              Name: <input name="name">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      Device ID: <input name="deviceID">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              Expiry: <input type="date" name="expiry">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      <button>➕ Add</button>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            </form>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <h2>📱 Detected Devices</h2>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        ${filteredDetected.map(d=>`
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <div class="card">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          <b>App:</b> ${d.appName}<br>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    <b>Device ID:</b> ${d.deviceID}<br>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              Requests: ${d.count}<br>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        Last Seen: ${d.lastSeen}<br><br>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <form method="POST" action="/hrtvdashboard/allow">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              <input type="hidden" name="deviceID" value="${d.deviceID}">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          <input type="hidden" name="name" value="${d.appName} - ${d.deviceID}">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      Expiry: <input type="date" name="expiry">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <button>✅ Allow</button>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            </form>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      <!-- 🆕 DELETE DETECTED DEVICE -->
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <form method="POST" action="/hrtvdashboard/delete-detected">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <input type="hidden" name="deviceID" value="${d.deviceID}">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <button>🗑 Delete Device</button>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  </form>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                `).join("")}

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      </body></html>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            `, { headers: { "Content-Type": "text/html; charset=UTF-8" }});
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                }

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    /* ================= DASHBOARD ACTIONS ================= */
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        if (path.startsWith("/hrtvdashboard/") && request.method === "POST") {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              const form = await request.formData();

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    if (path.endsWith("/add")) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            allowedDevices.push({
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      name: form.get("name"),
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                deviceID: form.get("deviceID"),
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          expiry: form.get("expiry")
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        }

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              if (path.endsWith("/edit")) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      const oldDeviceID = form.get("oldDeviceID");
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              const index = allowedDevices.findIndex(d => d.deviceID === oldDeviceID);
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      if (index !== -1) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                allowedDevices[index] = {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            name: form.get("name"),
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        deviceID: form.get("deviceID"),
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    expiry: form.get("expiry")
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              };
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            }

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  if (path.endsWith("/delete")) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          const deviceID = form.get("deviceID");
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  allowedDevices = allowedDevices.filter(d => d.deviceID !== deviceID);
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        }

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              if (path.endsWith("/allow")) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      const deviceID = form.get("deviceID");
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              const name = form.get("name");
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      const expiry = form.get("expiry");
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              if (!allowedDevices.some(d => d.deviceID === deviceID)) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        allowedDevices.push({ name, deviceID, expiry });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      }

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            // 🆕 DELETE DETECTED DEVICE ACTION
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  if (path.endsWith("/delete-detected")) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          const deviceID = form.get("deviceID");
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  detectedDevices = detectedDevices.filter(d => d.deviceID !== deviceID);
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          await env.HONOR_KV.put("detectedDevices", JSON.stringify(detectedDevices));
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  return Response.redirect(url.origin + "/hrtvdashboard", 302);
